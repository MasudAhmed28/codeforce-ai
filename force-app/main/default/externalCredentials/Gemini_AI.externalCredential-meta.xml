<?xml version="1.0" encoding="UTF-8"?>
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <authenticationProtocol>Custom</authenticationProtocol>
    <description>Authentication for Google Gemini AI API. After installation, edit the NamedPrincipal to add your Gemini API key.</description>
    <externalCredentialParameters>
        <parameterGroup>DefaultGroup</parameterGroup>
        <parameterName>x-goog-api-key</parameterName>
        <parameterType>AuthHeader</parameterType>
        <parameterValue>{!$Credential.Gemini_AI.ApiKey}</parameterValue>
        <sequenceNumber>2</sequenceNumber>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterGroup>Principal</parameterGroup>
        <parameterName>Principal</parameterName>
        <parameterType>NamedPrincipal</parameterType>
        <sequenceNumber>1</sequenceNumber>
    </externalCredentialParameters>
    <label>Gemini AI</label>
</ExternalCredential>
